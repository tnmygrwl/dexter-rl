# ──────────────────────────────────────────────
# Dexter App — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# All variables use the EXPO_PUBLIC_ prefix so they're
# available client-side via process.env.EXPO_PUBLIC_*
# ──────────────────────────────────────────────

# ── Browserbase ──────────────────────────────
# Sign up at https://www.browserbase.com
# API key: Settings → API Keys
# Project ID: visible in the dashboard URL or Settings → General
EXPO_PUBLIC_BROWSERBASE_API_KEY=bb_live_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_BROWSERBASE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Google Gemini ────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens per day (sufficient for dev)
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Gemini Model (tab generation) ─────────────
# Pick which Gemini model to use for tab generation.
# Options (as of March 2026):
#   gemini-2.5-flash              — stable, fast, GA (default)
#   gemini-2.5-pro                — stable, high quality
#   gemini-3-flash-preview        — frontier-class speed, preview
#   gemini-3.1-flash-lite-preview — budget, preview
#   gemini-3.1-pro-preview        — best quality, 1M context, preview
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# ── Gemini Live Model (real-time practice coaching) ─
# The Live API (BidiGenerateContent over WebSocket) only works
# with specific models. If you get "setup timed out", try a
# different model here.
# Known working:
#   gemini-2.0-flash-live-001                         — stable live
#   gemini-2.5-flash-native-audio-preview-12-2025     — enhanced audio
#   gemini-2.0-flash-exp                              — experimental
EXPO_PUBLIC_GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# ── Mock Data Toggle ────────────────────────
# Set to "false" to use live Songsterr + Gemini APIs
# Set to "true" (default) to use hardcoded demo songs
EXPO_PUBLIC_USE_MOCK_DATA=true
